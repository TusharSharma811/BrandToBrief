APP_NAME=BriefToBrand API
APP_VERSION=1.0.0
ENV=dev
CORS_ORIGINS=http://localhost:3000

GOOGLE_CLOUD_PROJECT=gemini-hacathon-project
GOOGLE_CLOUD_REGION=us-central1
GCS_BUCKET_NAME=your-campaign-assets-bucket

GEMINI_USE_VERTEX=false
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# Preferred for local development. If this is set, the backend uses the API key flow.
GEMINI_API_KEY=

# Image generation provider: "huggingface" uses an open image model and a Hugging Face token.
IMAGE_PROVIDER=huggingface
HUGGING_FACE_API_KEY=
HUGGING_FACE_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# If true, returns mock campaign content when Gemini quota is exhausted (helpful for demos)
GEMINI_MOCK_ON_QUOTA_EXCEEDED=true

FIRESTORE_COLLECTION=campaigns

# Optional local fallback when Firestore credentials are unavailable
CAMPAIGN_STORAGE_DIR=./data/campaigns
